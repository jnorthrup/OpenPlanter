{
  "providers": [
    {
      "id": "anthropic",
      "description": "Anthropic models",
      "defaultModel": "claude-opus-4-6",
      "models": [
        { "id": "claude-opus-4-6", "name": "Claude Opus 4.6" },
        { "id": "claude-sonnet-4-5", "name": "Claude Sonnet 4.5" },
        { "id": "claude-haiku-4-5", "name": "Claude Haiku 4.5" }
      ],
      "inferRules": [
        { "match": "prefix:claude" }
      ]
    },
    {
      "id": "openai",
      "description": "OpenAI models",
      "defaultModel": "gpt-5.2",
      "models": [
        { "id": "gpt-5.2", "name": "GPT-5.2" },
        { "id": "gpt-4o", "name": "GPT-4o" },
        { "id": "gpt-4o-mini", "name": "GPT-4o Mini" },
        { "id": "o1", "name": "o1" },
        { "id": "o3", "name": "o3" },
        { "id": "o4-mini", "name": "o4-mini" }
      ],
      "inferRules": [
        { "match": "prefix:gpt" },
        { "match": "prefix:o1-" },
        { "match": "exact:o1" },
        { "match": "prefix:o3-" },
        { "match": "exact:o3" },
        { "match": "prefix:o4-" },
        { "match": "prefix:chatgpt" },
        { "match": "prefix:dall-e" },
        { "match": "prefix:tts-" },
        { "match": "prefix:whisper" }
      ]
    },
    {
      "id": "openrouter",
      "description": "OpenRouter models",
      "defaultModel": "anthropic/claude-sonnet-4-5",
      "models": [
        { "id": "anthropic/claude-sonnet-4-5", "name": "Claude Sonnet 4.5 (OR)" },
        { "id": "anthropic/claude-opus-4-6", "name": "Claude Opus 4.6 (OR)" },
        { "id": "openai/gpt-5.2", "name": "GPT-5.2 (OR)" }
      ],
      "inferRules": [
        { "match": "contains:/" }
      ]
    },
    {
      "id": "cerebras",
      "description": "Cerebras models",
      "defaultModel": "qwen-3-235b-a22b-instruct-2507",
      "models": [
        { "id": "qwen-3-235b-a22b-instruct-2507", "name": "Qwen-3 235B" },
        { "id": "llama-4-scout-17b-16e-instruct", "name": "Llama-4 Scout" }
      ],
      "inferRules": [
        { "match": "exact:qwen-3" },
        { "match": "prefix:qwen-3-" },
        { "match": "prefix:llama-4-scout-17b-16e-instruct" },
        { "match": "prefix:gpt-oss" },
        { "match": "prefix:zai-glm" }
      ]
    },
    {
      "id": "ollama",
      "description": "Local Ollama models",
      "defaultModel": "llama3.2",
      "models": [
        { "id": "llama3.2", "name": "Llama 3.2" },
        { "id": "mistral", "name": "Mistral" },
        { "id": "gemma", "name": "Gemma" },
        { "id": "phi", "name": "Phi" },
        { "id": "deepseek", "name": "DeepSeek" },
        { "id": "qwen2", "name": "Qwen 2" }
      ],
      "inferRules": [
        { "match": "prefix:llama" },
        { "match": "prefix:mistral" },
        { "match": "prefix:gemma" },
        { "match": "prefix:phi" },
        { "match": "prefix:codellama" },
        { "match": "prefix:deepseek" },
        { "match": "prefix:vicuna" },
        { "match": "prefix:tinyllama" },
        { "match": "prefix:neural-chat" },
        { "match": "prefix:dolphin" },
        { "match": "prefix:wizardlm" },
        { "match": "prefix:orca" },
        { "match": "prefix:nous-hermes" },
        { "match": "prefix:command-r" },
        { "match": "prefix:qwen" }
      ]
    }
  ],
  "aliases": {
    "opus": "claude-opus-4-6",
    "sonnet": "claude-sonnet-4-5",
    "haiku": "claude-haiku-4-5",
    "sonnet-4": "claude-sonnet-4-5",
    "haiku-4": "claude-haiku-4-5",
    "opus-4": "claude-opus-4-6",
    "gpt5": "gpt-5.2",
    "gpt-5": "gpt-5.2",
    "gpt4o": "gpt-4o",
    "gpt-4o": "gpt-4o",
    "o1": "o1",
    "o3": "o3",
    "o4-mini": "o4-mini",
    "llama": "llama3.2",
    "mistral": "mistral",
    "gemma": "gemma",
    "phi": "phi",
    "deepseek": "deepseek",
    "qwen": "qwen-3-235b-a22b-instruct-2507",
    "qwen-3": "qwen-3-235b-a22b-instruct-2507"
  }
}
